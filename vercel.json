{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node tools/build.mjs && node tools/inject-token.mjs",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/carte-donnees/carte-embed(.html)?",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    }
  ]
}
